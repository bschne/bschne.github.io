---
import Base from './Base.astro';
import TopicList from '../components/TopicList.astro';
import '../styles/prose.css';
import { formatDate } from '../lib/dates';

interface Props {
  title: string;
  description?: string;
  date?: Date;
  topics?: string[];
}

const { title, description, date, topics = [] } = Astro.props;
---

<Base title={title} description={description}>
  <div class="prose-page">
    <header class="prose-header">
      {date && (
        <time class="post-date" datetime={date.toISOString()}>
          {formatDate(date)}
        </time>
      )}
    </header>
    <main class="prose-wrap">
      <article>
        <h1>{title}</h1>
        <div class="prose">
          <slot />
        </div>
        {topics.length > 0 && (
          <footer class="post-footer">
            <TopicList topics={topics} />
          </footer>
        )}
      </article>
    </main>
  </div>
</Base>

<style>
  .prose-page {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-2) var(--content-padding) var(--space-3);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .prose-header {
    align-self: stretch;
    border-top: 1px solid var(--color-accent);
    padding-top: var(--space-1);
    margin-bottom: var(--space-1-5);
  }

  .post-date {
    display: block;
    font-size: var(--text-meta);
    color: var(--color-text-secondary);
  }

  .prose-wrap {
    width: 100%;
    max-width: 680px;
  }

  .prose-wrap h1 {
    font-family: var(--font-sans);
    font-size: var(--text-h1);
    font-weight: 500;
    margin-bottom: var(--space-1-5);
  }

  .post-footer {
    margin-top: var(--space-2);
    padding-top: var(--space-1);
    border-top: 0.5px solid var(--color-border);
  }
</style>
