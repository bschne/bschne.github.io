---
import Base from './Base.astro';
import TopicList from '../components/TopicList.astro';
import '../styles/prose.css';
import { formatDate } from '../lib/dates';

interface Props {
  title: string;
  description?: string;
  date?: Date;
  topics?: string[];
}

const { title, description, date, topics = [] } = Astro.props;
---

<Base title={title} description={description}>
  <main class="prose-wrap">
    <article>
      <header class="prose-header">
        {date && (
          <time class="post-meta" datetime={date.toISOString()}>
            {formatDate(date)}
          </time>
        )}
        <h1>{title}</h1>
      </header>
      <div class="prose">
        <slot />
      </div>
      {topics.length > 0 && (
        <footer class="post-footer">
          <TopicList topics={topics} />
        </footer>
      )}
    </article>
  </main>
</Base>

<style>
  .prose-wrap {
    max-width: 680px;
    margin: 0 auto;
    padding: var(--space-2) var(--content-padding) var(--space-3);
  }

  .prose-header {
    margin-bottom: var(--space-1-5);
  }

  .post-meta {
    display: block;
    font-size: var(--text-meta);
    color: var(--color-text-secondary);
    margin-bottom: 0.5rem;
  }

  .prose-header h1 {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 500;
    line-height: 1.2;
  }

  .post-footer {
    margin-top: var(--space-2);
    padding-top: var(--space-1);
    border-top: 0.5px solid var(--color-border);
  }
</style>
