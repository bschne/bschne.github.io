---
import type { CollectionEntry } from 'astro:content';
import { formatDateShort } from '../lib/dates';

interface Props {
  item: CollectionEntry<'library'>;
  hasNote: boolean;
}

const { item, hasNote } = Astro.props;
const { type, title, creator, status, starred, date, url } = item.data;
const slug = item.id.replace(/\.mdx?$/, '');
const href = hasNote ? `/library/${slug}` : (url ?? null);
---

<li class="row">
  <span class="row-type">{type === 'podcast' ? 'pod' : type}</span>
  <span class="row-title">
    {href ? (
      <a href={href} class:list={{ 'row-note-link': hasNote }}>
        {title}
      </a>
    ) : title}
    {starred && <span class="row-star" aria-label="recommended"> ★</span>}
    <span class="row-creator"> · {creator.split(';')[0]}</span>
  </span>
  <span class="row-status">
    {status === 'now' ? 'now'
      : status === 'ongoing' ? 'ongoing'
      : date ? formatDateShort(date)
      : ''}
  </span>
</li>

<style>
  .row {
    display: grid;
    grid-template-columns: 4.5rem 1fr 5rem;
    gap: 0.75rem;
    padding: 0.5rem 0;
    border-bottom: 0.5px solid var(--color-border);
    align-items: baseline;
    font-size: var(--text-meta);
  }

  .row-type {
    color: var(--color-text-tertiary);
    font-variant-numeric: tabular-nums;
  }

  .row-title {
    color: var(--color-text-primary);
    line-height: 1.4;
  }

  .row-title a {
    text-decoration: none;
  }

  .row-title a:hover {
    color: var(--color-accent);
  }

  .row-note-link {
    text-decoration: underline;
    text-underline-offset: 0.15em;
    text-decoration-color: var(--color-border);
  }

  .row-star {
    color: var(--color-accent);
    font-size: 0.65rem;
  }

  .row-creator {
    color: var(--color-text-secondary);
  }

  .row-status {
    color: var(--color-text-tertiary);
    text-align: right;
    white-space: nowrap;
  }
</style>
