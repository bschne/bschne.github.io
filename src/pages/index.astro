---
import Editorial from '../layouts/Editorial.astro';
import TopicList from '../components/TopicList.astro';
import { getCollection } from 'astro:content';
import { jekyllPath, formatDate } from '../lib/dates';

const posts = await getCollection('writing', ({ data }) => !data.draft);
posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const selectedPosts = posts.filter(p => p.data.selected);
const featuredPosts = selectedPosts.length >= 4 ? selectedPosts.slice(0, 4) : posts.slice(0, 4);

const projects = await getCollection('projects');
projects.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const allTopics = [...new Set(posts.flatMap(p => p.data.topics))].sort();

const library = await getCollection('library');
const nowReading = library.filter(i => i.data.status === 'now' || i.data.status === 'ongoing');
---

<Editorial title="Benjamin Schneider">
  <div slot="header" class="site-header">
    <h1>Benjamin Schneider</h1>
    <p class="bio">
      Solution architect at Vivenu in Zurich. I contribute to OpenStreetMap, lead
      command support for a civil protection unit in the Pfannenstiel region, and
      read too much about hemoglobin, information design, and Central European history.
    </p>
    <nav class="contact-links">
      <a href="mailto:mail@benjaminschneider.ch">mail</a>
      <a href="https://twitter.com/bschne">twitter</a>
      <a href="https://bsky.app/profile/bschne.bsky.social">bluesky</a>
      <a href="https://linkedin.com/in/schneiderbenjamin">linkedin</a>
    </nav>
  </div>

  <div slot="main">
    <section class="home-section">
      <h2>Selected writing</h2>
      <ul class="writing-list">
        {featuredPosts.map(post => (
          <li>
            <a href={jekyllPath(post.data.date, post.id)}>{post.data.title}</a>
            {post.data.description && (
              <span class="item-desc"> — {post.data.description}</span>
            )}
          </li>
        ))}
      </ul>
      <a href="/writing" class="more-link">all writing, by topic →</a>
    </section>

    <section class="home-section">
      <h2>Projects</h2>
      <ul class="writing-list">
        {projects.slice(0, 4).map(project => (
          <li>
            {project.data.url ? (
              <a href={project.data.url}>{project.data.title}</a>
            ) : (
              <span class="item-title">{project.data.title}</span>
            )}
            <span class="item-desc"> — {project.data.summary}</span>
          </li>
        ))}
      </ul>
      <a href="/projects" class="more-link">all projects →</a>
    </section>
  </div>

  <div slot="rail">
    <section class="rail-section">
      <h3>now</h3>
      <p class="rail-text">
        Getting set up at Vivenu, re-learning molecular biology from the bottom up,
        and mapping the Pfannenstiel.
      </p>
      <a href="/now" class="rail-link">more →</a>
    </section>

    {nowReading.length > 0 && (
      <section class="rail-section">
        <h3>reading</h3>
        <ul class="reading-list">
          {nowReading.map(item => (
            <li>
              <a href={`/library/${item.id.replace(/\.mdx?$/, '')}`}>{item.data.title}</a>
              <span class="reading-creator"> · {item.data.creator.split(';')[0]}</span>
            </li>
          ))}
        </ul>
        <a href="/library" class="rail-link">library →</a>
      </section>
    )}

    {allTopics.length > 0 && (
      <section class="rail-section">
        <h3>topics</h3>
        <TopicList topics={allTopics} />
      </section>
    )}
  </div>
</Editorial>

<style>
  /* Header */
  .site-header h1 {
    font-size: 1.375rem;
    font-weight: 500;
    margin-bottom: 0.75rem;
  }

  .bio {
    font-size: var(--text-body);
    color: var(--color-text-primary);
    max-width: 52ch;
    margin-bottom: 0.875rem;
    line-height: 1.6;
  }

  .contact-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0 1.25rem;
    font-size: var(--text-meta);
    color: var(--color-text-secondary);
  }

  .contact-links a {
    text-decoration: none;
  }

  .contact-links a:hover {
    color: var(--color-accent);
  }

  /* Main column */
  .home-section {
    margin-bottom: var(--space-2-5);
  }

  .home-section h2 {
    font-size: var(--text-meta);
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: lowercase;
    color: var(--color-text-secondary);
    margin-bottom: 0.875rem;
  }

  .writing-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 0.875rem;
  }

  .writing-list li {
    font-family: var(--font-serif);
    font-size: var(--text-body);
    line-height: 1.4;
  }

  .writing-list a {
    text-decoration: underline;
    text-underline-offset: 0.15em;
    text-decoration-color: transparent;
  }

  .writing-list a:hover {
    text-decoration-color: var(--color-accent);
    color: var(--color-accent);
  }

  .item-title {
    font-family: var(--font-serif);
  }

  .item-desc {
    font-family: var(--font-sans);
    font-size: var(--text-meta);
    color: var(--color-text-secondary);
  }

  .more-link {
    font-size: var(--text-meta);
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .more-link:hover {
    color: var(--color-accent);
  }

  /* Rail */
  .rail-section {
    margin-bottom: var(--space-2);
  }

  .rail-section h3 {
    font-size: var(--text-meta);
    font-weight: 400;
    letter-spacing: 0.06em;
    color: var(--color-text-secondary);
    margin-bottom: 0.5rem;
  }

  .rail-text {
    font-size: var(--text-meta);
    color: var(--color-text-primary);
    line-height: 1.6;
    margin-bottom: 0.375rem;
  }

  .rail-link {
    font-size: var(--text-meta);
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .rail-link:hover {
    color: var(--color-accent);
  }


  .reading-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    margin-bottom: 0.375rem;
    font-size: var(--text-meta);
  }

  .reading-list a {
    text-decoration: none;
    color: var(--color-text-primary);
  }

  .reading-list a:hover {
    color: var(--color-accent);
  }

  .reading-creator {
    color: var(--color-text-secondary);
  }
</style>
