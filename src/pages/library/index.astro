---
import Base from '../../layouts/Base.astro';
import LibraryRow from '../../components/LibraryRow.astro';
import { getCollection } from 'astro:content';

const allItems = await getCollection('library');
allItems.sort((a, b) => {
  if (a.data.status === 'ongoing' && b.data.status !== 'ongoing') return -1;
  if (b.data.status === 'ongoing' && a.data.status !== 'ongoing') return 1;
  if (a.data.date && b.data.date) return b.data.date.getTime() - a.data.date.getTime();
  return a.data.title.localeCompare(b.data.title);
});

const itemsWithNotes = new Set(
  allItems.filter(i => i.body && i.body.trim().length > 0 && !i.data.inline).map(i => i.id)
);

const nowItems = allItems.filter(i => i.data.status === 'now');
const restItems = allItems.filter(i => i.data.status !== 'now');

const types = ['books', 'papers', 'podcasts', 'films', 'courses'] as const;
---

<Base title="Library" description="Books, papers, podcasts, films, and courses — things Benjamin Schneider has spent real time with.">
  <main class="page-wrap">
    <header class="library-header">
      <h1>Library</h1>
      <p class="library-desc">Books, papers, podcasts, films, courses — things I've spent real time with.</p>
      <nav class="type-nav">
        <a href="/library" class="type-active">all</a>
        {types.map(t => <a href={`/library/${t}`}>{t}</a>)}
      </nav>
    </header>

    {nowItems.length > 0 && (
      <section class="now-section">
        <h2 class="now-heading">Now</h2>
        <ul class="row-list">
          {nowItems.map(item => (
            <LibraryRow item={item} hasNote={itemsWithNotes.has(item.id)} />
          ))}
        </ul>
      </section>
    )}

    <ul class="row-list">
      {restItems.map(item => (
        <LibraryRow item={item} hasNote={itemsWithNotes.has(item.id)} />
      ))}
    </ul>
  </main>
</Base>

<style>
  .page-wrap {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-2) var(--content-padding) var(--space-3);
  }

  .library-header {
    margin-bottom: var(--space-2);
  }

  h1 {
    font-size: var(--text-h1);
    font-weight: 500;
    margin-bottom: 0.5rem;
  }

  .library-desc {
    font-size: var(--text-meta);
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
  }

  .type-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0 1.25rem;
    font-size: var(--text-meta);
    color: var(--color-text-secondary);
    padding-bottom: var(--space-1);
    border-bottom: 0.5px solid var(--color-border);
  }
  .type-nav a { text-decoration: none; }
  .type-nav a:hover { color: var(--color-accent); }
  .type-active { color: var(--color-text-primary); font-weight: 500; }

  .now-section {
    border-left: 2px solid var(--color-accent);
    margin-left: -1rem;
    padding-left: 1rem;
    margin-bottom: var(--space-2);
  }

  .now-heading {
    font-size: var(--text-meta);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    margin-bottom: 0.25rem;
  }

  .row-list { list-style: none; }
</style>
