---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import '../../styles/prose.css';

export async function getStaticPaths() {
  const RESERVED = new Set(['list', 'books', 'papers', 'podcasts', 'films', 'courses']);
  const items = await getCollection('library');
  return items
    .filter(item => {
      const slug = item.id.replace(/\.mdx?$/, '');
      return !RESERVED.has(slug) && item.body && item.body.trim().length > 0 && !item.data.inline;
    })
    .map(item => ({
      params: { slug: item.id.replace(/\.mdx?$/, '') },
      props: { item },
    }));
}

const { item } = Astro.props;
const { type, title, creator, status, date, url, topics } = item.data;
const { Content, headings } = await render(item);
const hasBody = item.body && item.body.trim().length > 0;

const typeLabel: Record<string, string> = {
  book: 'book', paper: 'paper', podcast: 'podcast', film: 'film', course: 'course',
};
---

<Base title={title}>
  <main class="page-wrap">
    <header class="item-header">
      <p class="item-back"><a href="/library">← library</a></p>
      <p class="item-type">{typeLabel[type]}</p>
      <h1>{title}</h1>
      <p class="item-creator">{creator}</p>
      {url && (
        <p class="item-link">
          <a href={url} target="_blank" rel="noopener">source ↗</a>
        </p>
      )}
      {status !== 'done' && (
        <p class="item-status">{status}</p>
      )}
    </header>

    {hasBody && (
      <div class="prose item-note">
        <Content />
      </div>
    )}
  </main>
</Base>

<style>
  .page-wrap {
    max-width: 680px;
    margin: 0 auto;
    padding: var(--space-2) var(--content-padding) var(--space-3);
  }

  .item-back {
    font-size: var(--text-meta);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-1);
  }
  .item-back a { text-decoration: none; }
  .item-back a:hover { color: var(--color-accent); }

  .item-type {
    font-size: var(--text-label);
    text-transform: lowercase;
    letter-spacing: 0.06em;
    color: var(--color-text-tertiary);
    margin-bottom: 0.375rem;
  }

  h1 {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    font-weight: 500;
    line-height: 1.2;
    margin-bottom: 0.375rem;
  }

  .item-creator {
    font-size: var(--text-meta);
    color: var(--color-text-secondary);
    margin-bottom: 0.5rem;
  }

  .item-link a {
    font-size: var(--text-meta);
    color: var(--color-text-secondary);
    text-decoration: none;
  }
  .item-link a:hover { color: var(--color-accent); }

  .item-status {
    display: inline-block;
    font-size: var(--text-label);
    text-transform: lowercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    margin-top: 0.25rem;
  }

  .item-note {
    margin-top: var(--space-2);
    padding-top: var(--space-1);
    border-top: 0.5px solid var(--color-border);
  }
</style>
