---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

const projects = await getCollection('work');
projects.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title="Work" description="Things Benjamin Schneider has built and organized.">
  <main class="page-wrap">
    <header class="page-header">
      <h1>Work</h1>
    </header>

    <ul class="project-list">
      {await Promise.all(projects.map(async project => {
        const { Content } = await render(project);
        return (
          <li class="project-item">
            <h2>
              {project.data.url ? (
                <a href={project.data.url}>{project.data.title}</a>
              ) : (
                project.data.title
              )}
            </h2>
            <div class="project-body">
              <Content />
            </div>
          </li>
        );
      }))}
    </ul>
  </main>
</Base>

<style>
  .page-wrap {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-2) var(--content-padding) var(--space-3);
  }

  .page-header {
    border-top: 1px solid var(--color-accent);
    padding-top: var(--space-1);
    margin-bottom: var(--space-2);
  }

  .page-header h1 {
    font-size: var(--text-h1);
    font-weight: 500;
  }

  .project-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    max-width: 42rem;
  }

  .project-item h2 {
    font-size: var(--text-h2);
    font-weight: 500;
    margin-bottom: 0.4rem;
  }

  .project-item h2 a {
    text-decoration: none;
  }

  .project-item h2 a:hover {
    color: var(--color-accent);
  }

  .project-body {
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .project-body p {
    margin: 0;
  }
</style>
